# Copy to .env for local dev. Do NOT commit .env.

PORT=4000
HOST=127.0.0.1

# Comma-separated origins allowed to send cookies. Match the FE dev server.
CORS_ORIGIN=http://localhost:3000

# 32+ random bytes. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_long_random_hex_in_dev_only

# Session cookie lifetime in days (default 7).
JWT_TTL_DAYS=7

# Password reset token lifetime in minutes (default 30).
RESET_TTL_MIN=30

# Auth rate limit + lockout.
# Per-IP request cap on /api/auth/* (10/min default).
AUTH_RATE_PER_MIN=10
# Per-email lockout: 5 failed logins in a 15-minute rolling window -> 423 lock.
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_WINDOW_MIN=15

# MongoDB connection. Point at a local mongod, Docker container, or Atlas cluster.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=skillgauge

# Active LLM provider. One of: stub | openai | anthropic | gemini.
# `stub` requires no key (deterministic; used by tests + dev). The other three each
# require their own key below — boot will fail with a clear error if the key is missing.
LLM_PROVIDER=stub

# OpenAI (used when LLM_PROVIDER=openai). Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-PASTE_YOUR_OPENAI_KEY_HERE
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (used when LLM_PROVIDER=anthropic). Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-PASTE_YOUR_ANTHROPIC_KEY_HERE
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini (used when LLM_PROVIDER=gemini). FREE tier with 1M-token context + 15 RPM.
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
# GEMINI_MODEL=gemini-2.0-flash

# Embeddings (Phase 6 — long-term memory store + Atlas Vector Search). Independent
# from LLM_PROVIDER because chat and embeddings are different endpoints.
#   stub  : deterministic hash-derived vectors. No key required. Storage path runs
#           end-to-end but vector search results are semantically meaningless.
#   gemini: reuses GEMINI_API_KEY. 768-dim vectors via gemini-embedding-001.
EMBEDDINGS_PROVIDER=stub
# GEMINI_EMBED_MODEL=gemini-embedding-001
# Vector dim must match the Atlas Search index spec (default 768 for stub + Gemini).
# EMBEDDINGS_DIMENSIONS=768

# Per-LLM-call timeout in milliseconds (default 30000).
# LLM_TIMEOUT_MS=30000

# Cost guards.
# Daily per-user token quota (resets at UTC midnight). 100k covers ~25 grading calls.
# DAILY_TOKEN_LIMIT=100000
# Max characters in a single LLM call's input (résumé + JD + history + prompt).
# MAX_INPUT_CHARS=60000
